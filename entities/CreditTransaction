{
  "name": "CreditTransaction",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "type": {
      "type": "string",
      "enum": [
        "earn",
        "spend",
        "withdraw",
        "bonus"
      ]
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed"
      ],
      "default": "completed"
    },
    "bank_account": {
      "type": "string"
    },
    "reference_id": {
      "type": "string"
    }
  },
  "required": [
    "user_id",
    "amount",
    "type"
  ]
}